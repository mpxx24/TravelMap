@{
    var isAuthenticated = User?.Identity?.IsAuthenticated == true;
    var userName = User?.Identity?.Name ?? "";
    var userEmail = User?.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value ?? "";
    var avatarUrl = User?.FindFirst("urn:google:picture")?.Value ?? "";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>TravelMap</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" crossorigin="" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <!-- Auth bar (top-right floating) -->
    <div class="auth-bar">
        @if (isAuthenticated)
        {
            @if (!string.IsNullOrEmpty(avatarUrl))
            {
                <img src="@avatarUrl" alt="@userName" class="auth-avatar" referrerpolicy="no-referrer" />
            }
            <span class="auth-name">@userName</span>
            <button id="share-btn" class="auth-btn" title="Share your map">
                <i class="bi bi-share"></i>
            </button>
            <form method="post" asp-controller="Account" asp-action="Logout" class="d-inline">
                <button type="submit" class="auth-btn" title="Sign out">
                    <i class="bi bi-box-arrow-right"></i>
                </button>
            </form>
        }
        else
        {
            <a href="/account/login" class="auth-btn auth-login">
                <i class="bi bi-google"></i> Sign in
            </a>
        }
        <button id="theme-toggle" class="auth-btn" title="Toggle theme">
            <i class="bi bi-moon-stars" id="theme-icon"></i>
        </button>
    </div>

    @if (isAuthenticated)
    {
        <div id="share-panel" class="share-panel" hidden>
            <div class="share-panel-title"><i class="bi bi-share"></i> Share your map</div>
            <p class="share-panel-desc">Anyone with this link can view your map (read-only).</p>
            <div class="share-url-row">
                <input id="share-url-input" type="text" class="share-url-input" readonly placeholder="Click Generate to create a link">
                <button id="share-copy-btn" class="share-action-btn" title="Copy link" disabled>
                    <i class="bi bi-clipboard"></i>
                </button>
            </div>
            <div class="share-actions">
                <button id="share-generate-btn" class="share-action-btn share-generate">Generate link</button>
                <button id="share-revoke-btn" class="share-action-btn share-revoke" disabled>Revoke</button>
                <button id="share-close-btn" class="share-action-btn share-close">Close</button>
            </div>
        </div>
    }

    @RenderBody()

    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" crossorigin=""></script>
    <script>
        // Pass auth state to JS
        window.TravelMapConfig = {
            isAuthenticated: @(isAuthenticated ? "true" : "false"),
            userEmail: "@Html.Raw(System.Text.Encodings.Web.JavaScriptEncoder.Default.Encode(userEmail))",
            isReadOnly: @(ViewBag.IsReadOnly == true ? "true" : "false"),
            initialVisits: @Html.Raw(ViewBag.InitialVisitsJson ?? "null")
        };
    </script>
    <script src="~/js/travelmap.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
