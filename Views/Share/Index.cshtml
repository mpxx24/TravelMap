@{
    ViewData["Title"] = "Shared Travel Map";
}

<div id="map"></div>

<!-- Legend -->
<div class="map-legend" id="legend">
    <div class="legend-title">Travel Map</div>
    <div class="legend-item"><span class="legend-color" style="background:#28a745"></span> Mainland</div>
    <div class="legend-item"><span class="legend-color" style="background:#17a2b8"></span> Islands</div>
    <div class="legend-item"><span class="legend-color" style="background:#ffc107"></span> Both</div>
    <div class="legend-item"><span class="legend-color legend-wishlist"></span> Wishlist</div>
    <div class="legend-stats" id="legend-stats">0 / 195 countries (0%)</div>
    <button class="legend-toggle" id="legend-toggle" aria-expanded="false">&#9656; by continent</button>
    <div class="legend-breakdown" id="legend-breakdown"></div>
</div>

<div class="readonly-banner">
    <i class="bi bi-eye"></i> View-only shared map
</div>
